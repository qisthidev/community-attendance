{
  "name": "@remix-run/cli",
  "version": "0.2.0",
  "description": "Command-line interface for Remix",
  "author": "Michael Jackson <mjijackson@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remix-run/remix.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/remix-run/remix/tree/main/packages/cli#readme",
  "files": [
    "bootstrap",
    "LICENSE",
    "README.md",
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "type": "module",
  "engines": {
    "node": ">=24.3.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "semver": "^7.7.4",
    "@remix-run/test": "^0.3.0",
    "@remix-run/terminal": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/semver": "^7.5.8",
    "@typescript/native-preview": "7.0.0-dev.20251125.1",
    "@remix-run/assert": "^0.2.0"
  },
  "keywords": [
    "remix",
    "cli",
    "scaffold",
    "project",
    "command-line"
  ],
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "clean": "git clean -fdX",
    "test": "remix-test --concurrency 1",
    "typecheck": "tsgo --noEmit"
  }
}