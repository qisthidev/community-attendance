{
  "name": "@remix-run/test",
  "version": "0.3.0",
  "description": "A test framework for JavaScript and TypeScript projects",
  "author": "Shopify Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remix-run/remix.git",
    "directory": "packages/test"
  },
  "homepage": "https://github.com/remix-run/remix/tree/main/packages/test#readme",
  "files": [
    "tsconfig.json",
    "LICENSE",
    "README.md",
    "dist",
    "src",
    "!src/**/*.test.*"
  ],
  "type": "module",
  "engines": {
    "node": ">=24.3.0"
  },
  "bin": {
    "remix-test": "./dist/cli-entry.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./cli": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    }
  },
  "dependencies": {
    "es-module-lexer": "^2.0.0",
    "esbuild": "^0.27.1",
    "get-tsconfig": "^4.13.6",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "magic-string": "^0.30.21",
    "source-map-js": "^1.2.1",
    "tsx": "^4.21.0",
    "v8-to-istanbul": "^9.3.0",
    "@remix-run/terminal": "^0.1.0"
  },
  "peerDependencies": {
    "playwright": "^1.59.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/dom-navigation": "1.0.6",
    "@types/istanbul-lib-coverage": "^2.0.6",
    "@types/istanbul-lib-report": "^3.0.3",
    "@types/istanbul-reports": "^3.0.4",
    "@types/node": "^24.6.0",
    "@typescript/native-preview": "7.0.0-dev.20251125.1",
    "decamelize": "^6.0.1",
    "playwright": "^1.59.0",
    "@remix-run/node-fetch-server": "^0.13.1",
    "@remix-run/assert": "^0.2.0",
    "@remix-run/ui": "^0.1.1"
  },
  "keywords": [
    "testing",
    "browser",
    "test",
    "remix",
    "component",
    "playwright"
  ],
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "clean": "git clean -fdX",
    "test": "node src/cli-entry.ts",
    "test:bun": "bun --bun src/cli-entry.ts --type server",
    "typecheck": "tsgo --noEmit"
  }
}