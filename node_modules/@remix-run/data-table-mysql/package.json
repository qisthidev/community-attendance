{
  "name": "@remix-run/data-table-mysql",
  "version": "0.3.1",
  "description": "MySQL adapter for remix/data-table",
  "author": "Michael Jackson <mjijackson@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remix-run/remix.git",
    "directory": "packages/data-table-mysql"
  },
  "homepage": "https://github.com/remix-run/remix/tree/main/packages/data-table-mysql#readme",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@typescript/native-preview": "7.0.0-dev.20251125.1",
    "mysql2": "^3.15.3",
    "@remix-run/assert": "0.2.0",
    "@remix-run/data-table": "0.2.1",
    "@remix-run/test": "0.3.0"
  },
  "dependencies": {
    "@remix-run/data-table": "^0.2.1"
  },
  "peerDependencies": {
    "mysql2": "^3.15.3"
  },
  "peerDependenciesMeta": {
    "mysql2": {
      "optional": true
    }
  },
  "keywords": [
    "remix",
    "orm",
    "mysql",
    "database",
    "sql"
  ],
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "clean": "git clean -fdX",
    "test": "remix-test",
    "test:bun": "bun x --bun remix-test",
    "test:coverage": "remix-test --coverage",
    "typecheck": "tsgo --noEmit"
  }
}