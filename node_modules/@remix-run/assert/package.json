{
  "name": "@remix-run/assert",
  "version": "0.2.0",
  "description": "Node assert-compatible utilities for any JavaScript environment",
  "author": "Shopify Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remix-run/remix.git",
    "directory": "packages/assert"
  },
  "homepage": "https://github.com/remix-run/remix/tree/main/packages/assert#readme",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@typescript/native-preview": "7.0.0-dev.20251125.1"
  },
  "keywords": [
    "assert",
    "assertions",
    "remix",
    "testing"
  ],
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "clean": "git clean -fdX",
    "test": "node --test",
    "test:bun": "bun test",
    "typecheck": "tsgo --noEmit"
  }
}