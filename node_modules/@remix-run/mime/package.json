{
  "name": "@remix-run/mime",
  "version": "0.4.1",
  "description": "Utilities for working with MIME types",
  "author": "Michael Jackson <mjijackson@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remix-run/remix.git",
    "directory": "packages/mime"
  },
  "homepage": "https://github.com/remix-run/remix/tree/main/packages/mime#readme",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@typescript/native-preview": "7.0.0-dev.20251125.1",
    "mime-db": "^1.53.0",
    "@remix-run/assert": "0.1.0",
    "@remix-run/test": "0.2.0"
  },
  "keywords": [
    "mime",
    "mime-type",
    "media-type",
    "content-type",
    "compressible"
  ],
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "clean": "git clean -fdX",
    "codegen": "node ./scripts/codegen.ts",
    "test": "remix-test",
    "test:bun": "bun x --bun remix-test",
    "typecheck": "tsgo --noEmit"
  }
}